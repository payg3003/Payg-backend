# ─── DATABASE ─────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/payg
JWT_SECRET=replace_with_64_byte_hex_run_node_crypto_randomBytes
JWT_EXPIRES_IN=30d

# ─── AFRICA'S TALKING (replaces Termii) ───────────────────────────────────────
# Get from: africastalking.com → Dashboard → Settings → API Key
AT_API_KEY=your_at_api_key
AT_USERNAME=your_at_username          # "sandbox" for testing, your app name for production
AT_SENDER_ID=PAYG                     # Alphanumeric sender ID (approved by AT)

# USSD service code (request from AT Dashboard → USSD → Create Channel)
# Shared code example: *384*123#  |  Dedicated: *123# (costs more)
AT_USSD_CODE=*384*123#

# ─── PAYSTACK ─────────────────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── SERVER ───────────────────────────────────────────────────────────────────
FRONTEND_URL=https://payg.ng
OTP_EXPIRES_MINUTES=10
NODE_ENV=development

# ─── NOTES ────────────────────────────────────────────────────────────────────
# Africa's Talking sandbox:
#   AT_USERNAME=sandbox
#   AT_API_KEY=<from sandbox dashboard>
#   Test SMS/USSD via: developers.africastalking.com/simulator
#
# USSD callback URL (set in AT dashboard):
#   https://your-backend.onrender.com/api/ussd
#
# Airtime notification URL (set in AT dashboard):
#   https://your-backend.onrender.com/api/airtime/callback
#
# Generate JWT_SECRET:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
